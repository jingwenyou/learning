│       │                    # ├── scan_port()          单端口扫描
│       │                    # └── scan_ports()          批量端口扫描
│       │
│       ├── process_monitor.py # 进程监控
│       │                    # ├── get_process_info()    进程详情
│       │                    # ├── get_top_processes()  TOP N进程
│       │                    # ├── get_process_summary() 进程概览
│       │                    # └── find_zombie_processes() 僵尸进程
│       │
│       ├── types.py          # Type Hints 数据类定义
│       │                    # ├── CPUInfo, MemoryInfo, DiskInfo
│       │                    # ├── NetworkInfo, ProcessInfo
│       │                    # └── HealthCheckResult
│       │
│       └── report_generator.py # 报告生成
│                            # ├── generate()           生成报告
│                            # ├── JSON格式              结构化数据
│                            # ├── HTML格式              可视化页面
│                            # └── Markdown格式          文档格式
│
│   └── utils/                # 工具模块
│       ├── logging_config.py # 结构化日志（JSON格式）
│       └── validators.py     # 输入验证（防注入）
│
├── tests/                   # 单元测试
│   ├── __init__.py
